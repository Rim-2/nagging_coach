# Gemini API 키 — https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=your-gemini-key-here

# 텔레그램 봇 토큰 — 텔레그램에서 @BotFather 로 봇 생성 후 발급
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# (선택) Gemini 모델 이름 — 미설정 시 ai_engine.py 의 DEFAULT_MODEL 사용
# flash-lite 계열은 함수 호출(목표·진척 자동 저장)이 들쭉날쭉해서 비추천
# GEMINI_MODEL=gemini-3-flash-preview

# (선택) PC 활동 감시 켜기 — true/false (기본: false)
# true 일 때만 화면·입력을 감시해 딴짓 시 잔소리를 보낸다.
# pygetwindow·pynput 패키지가 설치돼 있어야 한다.
ENABLE_PC_TRACKER=false
