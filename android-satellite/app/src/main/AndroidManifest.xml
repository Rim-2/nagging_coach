<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 네트워크 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 앱 사용 시간 — 일반 권한이 아니라 사용자가 설정에서 직접 허용해야 함 -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <!-- Foreground Service (Android 9+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- 알림 (Android 13+) — Foreground service 알림 표시용 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 만보계 (Android 10+) — 사용자가 설정에서 활동 인식 권한 허용 필요 -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <!-- 위치 카테고리 — 정확 좌표는 폰 안에서 매칭하고 백엔드엔 라벨만 보냄. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Android 10+ 백그라운드 위치: Foreground service 가 켜진 상태에선 즉시 -->
    <!-- 위치 요청이 가능하므로 BACKGROUND_LOCATION 은 *생략* — 권한 절차 부담↓ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <application
        android:label="@string/app_name"
        android:icon="@android:drawable/sym_def_app_icon"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar"
        android:allowBackup="false"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".TrackerService"
            android:exported="false"
            android:foregroundServiceType="dataSync|location" />

    </application>
</manifest>
